# ============================================================
#  MemeDrop — configuration (.env)
#  EVERYTHING IS OPTIONAL. With no .env at all, MemeDrop:
#   • auto-generates JWT_SECRET / ENCRYPTION_KEY (persisted in DATA_DIR/.secrets.json)
#   • auto-generates the admin password and prints it in the logs on first start
# ============================================================

# --- Server ---------------------------------------------------------------
# Public URL your users will use to reach MemeDrop (panel, editor, media).
# IMPORTANT for Discord OAuth and for media links sent to clients.
PUBLIC_URL=http://localhost:8080
# Host port (docker compose maps it to the container's 8080).
PORT=8080

# --- Secrets (leave empty to auto-generate) -------------------------------
# openssl rand -hex 32
JWT_SECRET=
ENCRYPTION_KEY=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# --- Discord (optional) ---------------------------------------------------
# Bot token (Discord developer portal -> Bot). Enables /meme, /link, /feed...
DISCORD_TOKEN=
# OAuth2 (same application): enables "Sign in with Discord" on the panel.
# Add this redirect URL in the portal:  <PUBLIC_URL>/api/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Only set if different from <PUBLIC_URL>/api/auth/discord/callback
DISCORD_REDIRECT_URI=

# --- GIF search (optional) ------------------------------------------------
# Free key at https://developers.giphy.com/ - enables GIF search in the editor.
GIPHY_API_KEY=

# --- Media limits (defaults shown) ----------------------------------------
MAX_UPLOAD_MB=25
MAX_VIDEO_DURATION_S=15
MAX_AUDIO_DURATION_S=15
MAX_TEXT_LENGTH=280

# --- Misc -----------------------------------------------------------------
LOG_LEVEL=info
# Which upstream may set X-Forwarded-For. The login rate limit counts per client
# IP, read from that header: trusting any caller lets an attacker forge it and
# get a fresh quota on every attempt.
# Default (empty): only loopback and private-range upstreams are trusted, which
# covers a reverse proxy running on the host or in a container.
# Harden by naming the proxy exactly, e.g. TRUST_PROXY=172.18.0.5
# Set TRUST_PROXY=false to never trust the header (all clients then share one
# rate-limit bucket).
TRUST_PROXY=
# DATA_DIR=/data   # container path - leave as-is with docker compose
